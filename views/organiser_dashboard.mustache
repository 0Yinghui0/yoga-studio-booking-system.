{{> head}}
{{> header}}

<div class="wrap" style="margin-top: 40px; margin-bottom: 50px;">
  
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
    <div>
      <h1 style="margin: 0; color: var(--dark-blue);">Organiser Dashboard</h1>
      <p class="muted" style="margin-top: 5px;">Welcome to the staff management portal.</p>
    </div>
    <div style="display: flex; gap: 15px;">
      <a href="/bookings/dashboard" class="btn primary">My Personal Bookings</a>
      <a href="/organiser/users" class="btn primary">Manage Users & Staff</a>
    </div>
  </div>

  <div style="background-color: var(--light-blue); padding: 25px; border-radius: 8px; margin-bottom: 30px; border: 1px solid rgba(33, 150, 243, 0.2);">
    <h3 style="color: var(--dark-blue); margin-top: 0; margin-bottom: 12px; font-size: 1.1em;">How to set up your classes:</h3>
    <ol style="margin: 0; padding-left: 20px; color: var(--ink); line-height: 1.6;">
      <li><strong>Step 1:</strong> Create the main <strong>Course</strong> using the form below.</li>
      <li><strong>Step 2:</strong> Find your new course in the table at the bottom and click the blue <strong>Edit</strong> button.</li>
      <li><strong>Step 3:</strong> Inside the Edit page, use the <strong>"Add a New Session"</strong> tool to create the individual dates and times for that course.</li>
    </ol>
  </div>

<article class="card" style="padding: 30px; margin-bottom: 40px;">
    <h2 style="margin-top: 0; color: var(--dark-blue); border-bottom: none;">Add a New Course</h2>
    
    <form action="/organiser/add" method="POST">
      <div style="margin-bottom: 15px;">
        <label style="color: var(--muted); font-weight: 600;">Title:</label>
        <input type="text" name="title" required>
      </div>
      
      <div style="margin-bottom: 15px;">
        <label style="color: var(--muted); font-weight: 600;">Level:</label>
        <select name="level">
          <option value="beginner">Beginner</option>
          <option value="intermediate">Intermediate</option>
          <option value="advanced">Advanced</option>
        </select>
      </div>

      <div style="display: flex; gap: 15px; margin-bottom: 15px;">
        <div style="flex: 1;">
          <label style="color: var(--muted); font-weight: 600;">Start Date:</label>
          <input type="date" name="startDate" required>
        </div>
        <div style="flex: 1;">
          <label style="color: var(--muted); font-weight: 600;">End Date:</label>
          <input type="date" name="endDate" required>
        </div>
      </div>

      <div style="margin-bottom: 15px;">
        <label style="color: var(--muted); font-weight: 600;">Description:</label>
        <textarea name="description" rows="3" required></textarea>
      </div>

      <div style="margin-bottom: 15px;">
        <label style="color: var(--muted); font-weight: 600;">Location:</label>
        <input type="text" name="location" placeholder="e.g., Main Studio" required>
      </div>

    <div style="display: flex; gap: 15px; margin-bottom: 15px;">
        <div style="flex: 1;">
          <label style="color: var(--muted); font-weight: 600;">Full Course Price (£):</label><br>
          <input type="number" name="price" placeholder="e.g., 50.00" required min="0" step="0.01" style="width: 100%; padding: 10px; border: 1px solid var(--line); border-radius: 6px;">
        </div>
        <div style="flex: 1;">
          <label style="color: var(--muted); font-weight: 600;">Price per Session (£):</label><br>
          <input type="number" name="sessionPrice" placeholder="e.g., 10.00" required min="0" step="0.01" style="width: 100%; padding: 10px; border: 1px solid var(--line); border-radius: 6px;">
        </div>
      </div>

      <button type="submit" class="btn primary">Create Course</button>
    </form>
  </article>

  <h2 style="color: var(--dark-blue);">Manage Courses</h2>
  <table class="table">
    <thead>
      <tr>
        <th>Course Title</th>
        <th>Level</th>
        <th>Start Date</th>
        <th style="text-align: right;">Actions</th>
      </tr>
    </thead>
    <tbody>
      {{#courses}}
      <tr>
        <td style="font-weight: bold; color: var(--dark-blue);">{{title}}</td>
        <td>{{level}}</td>
        <td>{{startDate}}</td>
        <td style="text-align: right; display: flex; gap: 10px; justify-content: flex-end;">
          
          <a href="/organiser/participants/{{_id}}" class="btn primary" style="padding: 8px 15px; font-size: 0.9em;">Students</a>
          <a href="/organiser/edit/{{_id}}" class="btn primary" style="padding: 8px 15px; font-size: 0.9em;">Edit</a>
          
          <form action="/organiser/delete/{{_id}}" method="POST" onsubmit="return confirm('Are you sure you want to delete this entire course?');" style="margin: 0;">
            <button type="submit" class="btn btn-danger" style="padding: 8px 15px; font-size: 0.9em;">Delete</button>
          </form>

        </td>
      </tr>
      {{/courses}}

      {{^courses}}
      <tr>
        <td colspan="4" style="text-align: center; padding: 20px;" class="muted">No courses available. Create one above!</td>
      </tr>
      {{/courses}}
    </tbody>
  </table>

</div>

{{> footer}}