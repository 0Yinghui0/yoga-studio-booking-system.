{{> head}}
{{> header}}

<article style="max-width: 500px; margin: 40px auto; padding: 20px; background-color: #f9f9f9; border-radius: 8px;">
  <h2 style="text-align: center;">Create an Account</h2>

  {{#error}}
    <div style="background-color: #ffdddd; color: #f44336; padding: 10px; border-radius: 5px; margin-bottom: 15px; text-align: center;">
      {{error}}
    </div>
  {{/error}}

  <form action="/auth/register" method="POST">
    <div style="margin-bottom: 15px;">
      <label><strong>Full Name:</strong></label><br>
      <input type="text" name="name" required style="width: 100%; padding: 10px; margin-top: 5px;">
    </div>

    <div style="margin-bottom: 15px;">
      <label><strong>Email:</strong></label><br>
      <input type="email" name="email" required style="width: 100%; padding: 10px; margin-top: 5px;">
    </div>
    
    <div style="margin-bottom: 20px;">
      <label><strong>Password:</strong></label><br>
      <input type="password" name="password" required style="width: 100%; padding: 10px; margin-top: 5px;">
    </div>

    <div style="margin-bottom: 15px;">
      <label><strong>I am a:</strong></label><br>
      <select name="role" style="width: 100%; padding: 10px; margin-top: 5px;">
        <option value="user">Yoga Student</option>
        <option value="organiser">Studio Organiser</option>
      </select>
    </div>

    <div style="margin-bottom: 20px;">
      <label><strong>Staff Passcode (Leave blank if Student):</strong></label><br>
      <input type="password" name="staffPasscode" placeholder="Enter secret code..." style="width: 100%; padding: 10px; margin-top: 5px;">
    </div>

    <button type="submit" class="btn" style="width: 100%; background-color: #4CAF50; color: white; padding: 12px; border: none; font-size: 16px; cursor: pointer;">Register</button>
  </form>
</article>

{{> footer}}