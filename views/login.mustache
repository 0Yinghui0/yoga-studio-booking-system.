{{> head}}
{{> header}}

<article style="max-width: 500px; margin: 40px auto; padding: 20px; background-color: #f9f9f9; border-radius: 8px;">
  <h2 style="text-align: center;">Welcome Back</h2>
  
  {{#error}}
    <div style="background-color: #ffdddd; color: #f44336; padding: 10px; border-radius: 5px; margin-bottom: 15px; text-align: center;">
      {{error}}
    </div>
  {{/error}}

  <form action="/auth/login" method="POST">
    <div style="margin-bottom: 15px;">
      <label><strong>Email:</strong></label><br>
      <input type="email" name="email" required style="width: 100%; padding: 10px; margin-top: 5px;" placeholder="name@example.com">
    </div>
    
    <div style="margin-bottom: 20px;">
      <label><strong>Password:</strong></label><br>
      <input type="password" name="password" required style="width: 100%; padding: 10px; margin-top: 5px;">
    </div>

    <button type="submit" class="btn" style="width: 100%; background-color: #2196F3; color: white; padding: 12px; border: none; font-size: 16px; cursor: pointer;">Login</button>
  </form>
  
  <p style="text-align: center; margin-top: 20px;">
    Don't have an account? <a href="/auth/register" style="color: #2196F3;">Register here</a>
  </p>
</article>

{{> footer}}